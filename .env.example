# Copy this file to .env and fill in your own keys.
# .env is git-ignored — never commit real API keys.

# Groq API key — used for LLM conversation (Llama 3.3 70B)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# NewsAPI key — used to fetch live news headlines
# Get one at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here
